OPENAI_API_KEY=sk-...

# Model used by the main stem agent during all phases.
STEMCELL_MODEL=gpt-5.5

# Model used by the `single_shot` helper inside agent-authored Python scripts.
# Cheap by default since each call is one shot.
STEMCELL_TOOL_MODEL=gpt-5-mini

# Model used inside domain tests.py for LLM-as-judge verification (if a domain
# uses it). Distinct from the above so judge cost/capability can be tuned
# independently of training cost.
STEMCELL_TEST_MODEL=gpt-5.5
